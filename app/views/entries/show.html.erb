<% content_for :title, @entry.title %>

<div class="container mt-4">

  <h1><%= @entry.title %></h1>

  <div class="mb-3">
    <% @entry.tags.each do |tag| %>
      <span class="badge text-bg-secondary"><%= tag.name %></span>
    <% end %>

    <% if @entry.rating.present? %>
      <span class="badge text-bg-dark">★ <%= @entry.rating %></span>
    <% end %>
  </div>

  <div class="card mb-3">
    <div class="card-body">
      <%= simple_format(@entry.body) %>
    </div>
  </div>

  <!-- いいねボタン -->
  <div class="mb-3">
    <% current = current_user || User.find_by(email: "guest@example.com") %>
    <% liked = current&.likes&.exists?(entry: @entry) %>

    <% if liked %>
      <%= button_to "❤️ いいね済み (#{@entry.likes.count})",
          entry_like_path(@entry),
          method: :delete,
          class: "btn btn-danger btn-sm" %>
    <% else %>
      <%= button_to "🤍 いいね (#{@entry.likes.count})",
          entry_like_path(@entry),
          method: :post,
          class: "btn btn-outline-danger btn-sm" %>
    <% end %>
  </div>

  <div class="mt-3">
    <%= link_to "編集", edit_entry_path(@entry), class: "btn btn-primary" %>
    <%= link_to "ホームへ戻る", root_path(scope: params[:scope]),
    class: "btn btn-outline-secondary" %>
    <%= link_to "削除", @entry,
        data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" },
        class: "btn btn-danger" %>
  </div>

</div>