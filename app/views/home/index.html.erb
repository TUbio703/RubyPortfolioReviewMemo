<div class="container mt-4">

  <h1 class="display-4 mb-4">
    Portfolio Review Memo
  </h1>

<div class="container mt-4">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="display-4 mb-0">Portfolio Review Memo</h1>

    <div class="d-flex align-items-center gap-2">
      <% if user_signed_in? %>
        <span class="text-muted small"><%= current_user.email %></span>
        <%= link_to "ログアウト", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-outline-danger btn-sm" %>
      <% else %>
        <%= link_to "ログイン", new_user_session_path, class: "btn btn-outline-primary btn-sm" %>
        <%= link_to "新規登録", new_user_registration_path, class: "btn btn-primary btn-sm" %>
      <% end %>
    </div>
  </div>

  <p>映画や音楽などのコンテンツを記録するサイト</p>
  
  <!-- 以下は既存のコードそのまま -->

  <h2>登録件数</h2>

  <p>
    <%= Entry.count %> 件
  </p>

  <div class="mb-4">
    <%= link_to "✏️ つくる", new_entry_path, class: "btn btn-success" %>
  </div>

  <div class="mb-3">
  <%= form_with url: root_path, method: :get, local: true do %>
    <div class="input-group">
      <%= text_field_tag :q, params[:q], class: "form-control", placeholder: "タイトル・タグで検索" %>
      <button class="btn btn-outline-primary" type="submit">検索</button>
    </div>
  <% end %>
</div>
<!-- タブ切り替え -->
<div class="mb-3">
  <%= link_to "自分の投稿", root_path(scope: "mine"),
      class: "btn btn-sm #{params[:scope] != 'everyone' ? 'btn-primary' : 'btn-outline-primary'}" %>
  <%= link_to "みんなの投稿", root_path(scope: "everyone"),
      class: "btn btn-sm #{params[:scope] == 'everyone' ? 'btn-primary' : 'btn-outline-primary'}" %>
</div>
<% if params[:q].present? || params[:tag].present? %>
  <div class="mb-3">
    <%= link_to "← 全て表示に戻る", root_path(scope: params[:scope]),
        class: "btn btn-outline-secondary btn-sm" %>
  </div>
<% end %>

  <h2>記録一覧</h2>

  <table class="table table-striped table-hover">
          <thead>
  <tr>
    <th>タイトル</th>
    <th>評価</th>
    <th>タグ</th>
    <th>感想</th>
    <th>いいね</th>
    <th></th>
  </tr>
</thead>

          <tbody>
  <% @entries.each do |entry| %>
    <tr>
      <td><%= entry.title %></td>
      <td><%= "★" * (entry.rating || 0) %></td>
      <td style="max-width: 150px; overflow: hidden; white-space: nowrap; text-overflow: ellipsis;">
        <% entry.tags.each do |tag| %>
          <%= link_to tag.name, root_path(tag: tag.name, scope: params[:scope]), class: "badge text-bg-primary text-decoration-none me-1" %>
        <% end %>
      </td>
      <td><%= truncate(entry.body, length: 40) %></td>
      <td>❤️ <%= entry.likes.count %></td>
      <td>
        <%= link_to "詳細", entry_path(entry, scope: params[:scope]), class: "btn btn-sm btn-primary" %>
      </td>
    </tr>
  <% end %>
</tbody>
  </table>

  <h2>最新の記録</h2>

  <% if @latest_entry %>
    <div class="card">
      <div class="card-body">
        <h5><%= @latest_entry.title %></h5>

        <p>
          <%= truncate(@latest_entry.body, length: 100) %>
        </p>
      </div>
    </div>
  <% else %>
    <p>まだ記録がありません。</p>
  <% end %>

</div>